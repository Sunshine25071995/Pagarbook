rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 📚 SUNSHINE PAGAR BOOK FIREBASE SECURITY RULES
    // Set these rules in your Firebase Console -> Firestore Database -> Rules tab

    // Admin has full read and write access.
    // Since the Node.js server proxies the operations, we allow general read/write.
    // If you plan to connect your client app directly to Firestore, you can uncomment the user-based rules below.

    match /{document=**} {
      allow read, write: if true;
    }

    /*
    // Production Secure Mode (Uncomment below to secure your direct client-side requests)
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /employees/{employeeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /monthly_records/{recordId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /withdrawals/{withdrawalId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /attendance/{attendanceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    */
  }
}
